# ============================================
# 骗子酒馆 · 环境变量配置示例
# ============================================
# 复制此文件为 .env 后按需修改：
# cp .env.example .env
#
# 默认值适用于 docker-compose 启动的整套服务。
# 如果只在宿主机本地运行 backend，请看每段下面的“本地调试”注释。
# ============================================

# ─── 服务端口 ───
SERVER_PORT=8080

# ─── 数据库（MySQL）───
# Docker Compose 内部服务名：
DB_HOST=mysql
DB_PORT=3306
DB_USER=liarsbar
DB_PASSWORD=liarsbar123
DB_NAME=liars_bar
#
# 本地调试 backend 时改成：
# DB_HOST=127.0.0.1
# DB_PORT=3307

# ─── 缓存（Redis）───
# Docker Compose 内部服务名：
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
#
# 本地调试 backend 时改成：
# REDIS_ADDR=127.0.0.1:6379

# ─── JWT 认证 ───
# 开发环境可以使用默认值，生产环境必须改成足够长的随机字符串。
JWT_SECRET=liars-bar-secret-key-2024

# ─── AI 服务 ───
# Docker Compose 内部服务名：
AI_SERVICE_URL=http://ai-service:8000
AI_ENABLED=true
#
# 本地调试 backend 时改成：
# AI_SERVICE_URL=http://127.0.0.1:8000

# ─── 游戏配置（可选，有默认值）───
# GAME_MAX_PLAYERS=4
# MATCH_TIMEOUT=10s
# AI_FILL_TIMEOUT=15s
# RECONNECT_TIMEOUT=30s
# MAX_CARDS_PLAY=3
