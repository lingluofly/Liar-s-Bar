# ============================================
# 骗子酒馆 · 环境变量配置示例
# ============================================
# 复制此文件为 .env 后按需修改
# cp .env.example .env
# ============================================

# ─── 服务端口 ───
SERVER_PORT=8080

# ─── 数据库（MySQL）───
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=liarsbar
DB_PASSWORD=liarsbar123
DB_NAME=liars_bar

# ─── 缓存（Redis）───
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=

# ─── JWT 认证 ───
JWT_SECRET=liars-bar-secret-key-2024

# ─── AI 服务 ───
AI_SERVICE_URL=http://127.0.0.1:8000
AI_ENABLED=true

# ─── 游戏配置（可选，有默认值）───
# GAME_MAX_PLAYERS=4
# MATCH_TIMEOUT=10s
# AI_FILL_TIMEOUT=15s
# RECONNECT_TIMEOUT=30s
# MAX_CARDS_PLAY=3
